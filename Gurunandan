<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Gurunandan — My World & Future Plans</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue-50: #E6F1FB; --blue-200: #85B7EB; --blue-400: #378ADD; --blue-800: #0C447C;
    --green-50: #EAF3DE; --green-200: #97C459; --green-800: #27500A;
    --amber-50: #FAEEDA; --amber-200: #FAC775; --amber-800: #633806;
    --teal-50: #E1F5EE; --teal-200: #5DCAA5; --teal-800: #085041;
    --coral-50: #FAECE7; --coral-200: #F0997B; --coral-800: #712B13;
    --purple-50: #EEEDFE; --purple-200: #AFA9EC; --purple-800: #3C3489;
    --pink-50: #FBEAF0; --pink-200: #ED93B1; --pink-800: #72243E;
    --gray-50: #F1EFE8; --gray-100: #D3D1C7; --gray-800: #444441;
  }

  body {
    font-family: 'Nunito', sans-serif;
    background: #FAFAF8;
    color: #2C2C2A;
    min-height: 100vh;
  }

  /* === HERO === */
  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero-photo {
    position: relative;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, #FAFAF8 100%);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3rem 4rem 2rem;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--blue-400);
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .hero-name {
    font-family: 'Baloo 2', cursive;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.0;
    color: #1a1a18;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.15s forwards;
  }

  .hero-name span {
    color: var(--blue-400);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: #5F5E5A;
    margin-top: 1rem;
    line-height: 1.6;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.3s forwards;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.45s forwards;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
  }

  .badge.b-blue { background: var(--blue-50); color: var(--blue-800); }
  .badge.b-green { background: var(--green-50); color: var(--green-800); }
  .badge.b-amber { background: var(--amber-50); color: var(--amber-800); }
  .badge.b-teal { background: var(--teal-50); color: var(--teal-800); }
  .badge.b-coral { background: var(--coral-50); color: var(--coral-800); }
  .badge.b-purple { background: var(--purple-50); color: var(--purple-800); }
  .badge.b-pink { background: var(--pink-50); color: var(--pink-800); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === MAIN CONTENT === */
  .main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .section-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--blue-400);
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-family: 'Baloo 2', cursive;
    font-size: 2rem;
    font-weight: 800;
    color: #1a1a18;
    margin-bottom: 2rem;
  }

  /* === CHARACTER TRAITS === */
  .traits-section {
    margin-bottom: 5rem;
  }

  .traits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .trait-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: 20px;
    padding: 1.5rem 1.25rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .trait-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    border-radius: 20px 20px 0 0;
  }

  .trait-card.t-blue::before { background: var(--blue-400); }
  .trait-card.t-green::before { background: var(--green-200); }
  .trait-card.t-amber::before { background: var(--amber-200); }
  .trait-card.t-teal::before { background: var(--teal-200); }
  .trait-card.t-coral::before { background: var(--coral-200); }
  .trait-card.t-purple::before { background: var(--purple-200); }

  .trait-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }

  .trait-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .trait-name {
    font-family: 'Baloo 2', cursive;
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a18;
    margin-bottom: 4px;
  }

  .trait-desc {
    font-size: 0.82rem;
    color: #888780;
    line-height: 1.5;
  }

  /* === TEACHER QUOTE === */
  .teacher-quote {
    background: linear-gradient(135deg, var(--amber-50), var(--coral-50));
    border-radius: 24px;
    padding: 2.5rem;
    margin-bottom: 5rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .quote-icon {
    font-size: 3rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .quote-text {
    font-family: 'Baloo 2', cursive;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--amber-800);
    line-height: 1.5;
    font-style: italic;
  }

  .quote-attr {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--coral-800);
    margin-top: 0.75rem;
  }

  /* === ACTIVITIES GRID === */
  .activities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 5rem;
  }

  .activity-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: 20px;
    padding: 1.5rem 1.25rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .activity-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }

  .activity-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .activity-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #2C2C2A;
  }

  .activity-desc {
    font-size: 0.8rem;
    color: #888780;
    margin-top: 4px;
  }

  /* === TIMELINE === */
  .timeline-section {
    margin-bottom: 5rem;
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 19px; top: 20px; bottom: 20px;
    width: 2px;
    background: linear-gradient(to bottom, var(--blue-200), var(--purple-200));
    border-radius: 2px;
  }

  .tl-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 2rem;
    position: relative;
  }

  .tl-dot {
    width: 40px; height: 40px; min-width: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    margin-left: -2rem;
    position: relative;
    z-index: 1;
    border: 2px solid white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .tl-dot.now { background: var(--blue-50); }
  .tl-dot.soon { background: var(--green-50); }
  .tl-dot.mid { background: var(--amber-50); }
  .tl-dot.dream { background: var(--purple-50); }

  .tl-body {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    flex: 1;
  }

  .tl-age {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #888780;
    margin-bottom: 4px;
  }

  .tl-title {
    font-family: 'Baloo 2', cursive;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a18;
    margin-bottom: 4px;
  }

  .tl-desc {
    font-size: 0.9rem;
    color: #5F5E5A;
    line-height: 1.6;
  }

  /* === FUN FACTS === */
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 5rem;
  }

  .fact-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: 16px;
    padding: 1.25rem;
  }

  .fact-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #888780;
    margin-bottom: 6px;
  }

  .fact-value {
    font-family: 'Baloo 2', cursive;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a18;
  }

  /* === FOOTER === */
  .footer {
    background: linear-gradient(135deg, var(--blue-50), var(--purple-50));
    border-radius: 24px;
    padding: 3rem;
    text-align: center;
  }

  .footer-emoji {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
  }

  .footer-msg {
    font-family: 'Baloo 2', cursive;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--blue-800);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .footer-sub {
    font-size: 1rem;
    color: var(--purple-800);
    font-weight: 600;
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-photo {
      height: 70vw;
    }
    .hero-photo::after {
      background: linear-gradient(to bottom, transparent 60%, #FAFAF8 100%);
    }
    .hero-content {
      padding: 2rem 1.5rem 3rem;
    }
    .activities-grid,
    .traits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .facts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .teacher-quote {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-photo">
    <img src="data:image/jpeg;base64," alt="Gurunandan at Google headquarters"/>
